# Copy this file to .env and fill in your own key. Never commit the real .env file.
OPENROUTER_API_KEY=your-openrouter-key-here

# Model used for LLM reasoning/summarization (never for prediction).
# openrouter/free auto-routes to a currently-available free model.
# Swap to a specific stable model before your final demo/deploy, e.g.:
#   meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=openrouter/free
